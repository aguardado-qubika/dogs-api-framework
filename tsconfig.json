{
    "compilerOptions": {
        "target": "ES2022",
        "module": "commonjs",
        "lib": [
            "ES2022",
            "dom",
            "ESNext.Disposable"
        ],
        "types": [
            "node"
        ],
        "strict": true,
        "esModuleInterop": true,
        "ignoreDeprecations": "6.0",
        "rootDir": ".",
        "outDir": "./dist",
        "baseUrl": ".",
        "paths": {
            "@controllers/*": [
                "src/controllers/*"
            ],
            "@fixtures/*": [
                "src/fixtures/*"
            ],
            "@utils/*": [
                "src/utils/*"
            ],
            "@data/*": [
                "src/data/*"
            ]
        }
    },
    "include": [
        "src/**/*",
        "tests/**/*",
        "global-setup.ts",
        "global-teardown.ts",
        "playwright.config.ts"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}